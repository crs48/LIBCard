---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import { getActiveTheme } from "../lib/config";

interface Props {
  title?: string;
  /** Widen the container (used by the multi-column theme gallery). */
  wide?: boolean;
}

const { title, wide } = Astro.props;
const maxWidth = wide ? "max-w-3xl" : "max-w-md";
// The owner's chosen theme is server-rendered into <html data-theme> so first
// paint, crawlers, and no-JS visitors all see it. The switcher (if enabled) only
// re-themes on interaction.
const theme = await getActiveTheme();
---
<!doctype html>
<html lang="en" data-theme={theme.name}>
  <head>
    <BaseHead title={title} />
    {
      /* No-flash: restore a returning visitor's chosen theme before first paint.
         Only emitted when the switcher is on — otherwise the page ships zero JS. */
      theme.switcher && (
        <script is:inline define:vars={{ allowed: theme.cycle }}>
          {`const t = localStorage.getItem("libcard-theme");
            if (t && allowed.includes(t)) document.documentElement.dataset.theme = t;`}
        </script>
      )
    }
  </head>
  <body class="min-h-dvh bg-bg font-sans antialiased">
    <div class:list={["mx-auto flex min-h-dvh w-full flex-col items-center px-4 py-10 sm:py-14", maxWidth]}>
      <main class="flex w-full flex-1 flex-col items-center gap-6">
        <slot />
      </main>
      {theme.switcher && <ThemeSwitcher />}
      <Footer />
    </div>
  </body>
</html>
