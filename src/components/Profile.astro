---
import { getConfig } from "../lib/config";
import { withBase } from "../lib/site";
import Icon from "./Icon.astro";

const { profile } = await getConfig();
const base = import.meta.env.BASE_URL;
const avatar = profile.avatar
  ? profile.avatar.startsWith("http")
    ? profile.avatar
    : withBase(base, profile.avatar)
  : withBase(base, "/avatar.svg");
---
<header class="flex flex-col items-center text-center gap-3">
  <img
    src={avatar}
    alt={`${profile.name}'s avatar`}
    width="96"
    height="96"
    loading="eager"
    decoding="async"
    class="size-24 rounded-full object-cover ring-2 ring-border shadow-sm bg-surface"
  />
  <h1 class="text-2xl font-bold tracking-tight text-fg">{profile.name}</h1>
  {profile.tagline && <p class="text-muted max-w-prose text-balance">{profile.tagline}</p>}
  {
    profile.location && (
      <p class="flex items-center gap-1 text-sm text-muted">
        <Icon name="map-pin" class="size-4" />
        <span>{profile.location}</span>
      </p>
    )
  }
</header>
