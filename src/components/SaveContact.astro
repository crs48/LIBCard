---
import { withBase } from "../lib/site";
import Icon from "./Icon.astro";

interface Props {
  label?: string;
  class?: string;
}

const { label = "Save contact", class: className } = Astro.props;
// Plain download link to the build-time vCard — tapping it on iOS/Android opens
// the native "Add to Contacts" sheet. No JavaScript involved.
const href = withBase(import.meta.env.BASE_URL, "/contact.vcf");
---
<a
  href={href}
  download="contact.vcf"
  class:list={[
    "inline-flex items-center justify-center gap-2 rounded-card bg-accent px-5 py-3 font-semibold text-accent-contrast shadow-sm transition hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent",
    className,
  ]}
>
  <Icon name="contact" class="size-5" />
  <span>{label}</span>
</a>
