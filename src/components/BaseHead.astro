---
import { getConfig, getAnalytics } from "../lib/config";
import { absoluteUrl, withBase } from "../lib/site";

interface Props {
  title?: string;
}

const cfg = await getConfig();
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;

const pageTitle = title ? `${title} · ${cfg.profile.name}` : `${cfg.profile.name} · LibCard`;
const description = cfg.seo?.description ?? cfg.profile.tagline ?? `${cfg.profile.name}'s links, all in one place.`;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;

const ogImage = cfg.seo?.ogImage
  ? cfg.seo.ogImage.startsWith("http")
    ? cfg.seo.ogImage
    : absoluteUrl(Astro.site, base, cfg.seo.ogImage)
  : absoluteUrl(Astro.site, base, "/og.png");

const favicon = withBase(base, "/favicon.svg");
const faviconPng = withBase(base, "/favicon-32.png");
const appleTouchIcon = withBase(base, "/apple-touch-icon.png");
const manifest = withBase(base, "/manifest.webmanifest");

// Opt-in, cookieless analytics. Null (the default) emits nothing — the page
// stays exactly as zero-JS as it was. Each beacon below is the provider's
// official, cookieless snippet; the GoatCounter `pixel` variant ships NO script
// and is emitted in the Layout body instead. See docs/explorations/0009.
const analytics = await getAnalytics();
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="icon" href={favicon} type="image/svg+xml" />
<link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href={appleTouchIcon} />
<link rel="manifest" href={manifest} />
<link rel="canonical" href={canonical} />

<!-- Open Graph / Twitter -->
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonical} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta name="generator" content={Astro.generator} />

{/* Cookieless analytics beacons (opt-in). The GoatCounter pixel ships no JS
    and is rendered in the body by Layout.astro instead. */}
{analytics?.provider === "plausible" && (
  <script is:inline defer data-domain={analytics.domain} src={analytics.src}></script>
)}
{analytics?.provider === "umami" && (
  <script is:inline defer src={analytics.src} data-website-id={analytics.websiteId}></script>
)}
{analytics?.provider === "cloudflare" && (
  <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${analytics.token}"}`}></script>
)}
{analytics?.provider === "goatcounter" && analytics.mode === "script" && (
  <script is:inline defer data-goatcounter={`https://${analytics.code}.goatcounter.com/count`} src="//gc.zgo.at/count.js"></script>
)}
