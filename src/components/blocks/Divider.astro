---
import type { BlockOf } from "../../lib/config";

interface Props {
  block: BlockOf<"divider">;
}

const { block } = Astro.props;
---
{
  block.label ? (
    <div class="flex w-full items-center gap-3 text-xs font-medium uppercase tracking-wide text-muted">
      <span class="h-px flex-1 bg-border" />
      <span>{block.label}</span>
      <span class="h-px flex-1 bg-border" />
    </div>
  ) : (
    <hr class="w-full border-0 border-t border-border" />
  )
}
