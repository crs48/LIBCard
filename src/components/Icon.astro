---
<svg
  viewBox="0 0 24 24"
  class={className}
  width="24"
  height="24"
  fill={icon.fill ? "currentColor" : "none"}
  stroke={icon.fill ? "none" : "currentColor"}
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={title ? undefined : "true"}
  role={title ? "img" : undefined}
>
  {title && <title>{title}</title>}
  <path d={icon.d} />
</svg>
